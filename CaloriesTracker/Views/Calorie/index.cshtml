@using CaloriesTracker.Models.Stats
@model DailySummary

@{
    ViewData["Title"] = "Daily Intake";
    var date = ViewBag.Date as DateTime? ?? DateTime.Today;
}

<div class="row mb-4">
    <div class="col-12">
        <h2>Daily Intake - @date.ToString("MMMM d, yyyy")</h2>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                @if (TempData["CopyMessage"] != null)
                {
                    <div class="alert alert-info">@TempData["CopyMessage"]</div>
                }
                <div class="row">
                    <div class="col-md-6">
                        <div class="row">
                            <div class="col-6>">
                                <h5>Calories</h5>
                                <div class="progress mb-3">
                                    @{
                                        var progressPercentage = Math.Min(100, (int)(Model.TotalCalories / ((Model.DailyGoal == 0)?1600:Model.DailyGoal) * 100));
                                    }
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @progressPercentage%"
                                         aria-valuenow="@progressPercentage"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                        @((int)Model.TotalCalories)/@((int)Model.DailyGoal)
                                    </div>
                                </div>
                            </div>
                            <div class="col-6>">
                                <h5>Protein</h5>
                                <div class="progress mb-3">
                                    @{
                                        var proteinPercentage = Math.Min(100, (int)(Model.TotalProtein / ((Model.ProteinGoal == 0) ? 100 : Model.ProteinGoal) * 100));
                                    }
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @proteinPercentage%"
                                         aria-valuenow="@proteinPercentage"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                        @((int)Model.TotalProtein)/@((int)Model.ProteinGoal)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="row">
                            <div class="col-4 text-center">
                                <h6>Protein</h6>
                                <p class="text-primary">@Model.TotalProtein.ToString("F1")g</p>
                            </div>
                            <div class="col-4 text-center">
                                <h6>Fat</h6>
                                <p class="text-warning">@Model.TotalFat.ToString("F1")g</p>
                            </div>
                            <div class="col-4 text-center">
                                <h6>Carbs</h6>
                                <p class="text-success">@Model.TotalCarbs.ToString("F1")g</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Add Food</h5>
            </div>
            <div class="card-body">
                <form asp-action="AddIntakeWithDate" method="post">
                    <div class="mb-3">
                        <label for="intakeDate" class="form-label">Date</label>
                        <input type="date" class="form-control" id="intakeDate" name="intakeDate"
                               value="@date.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="mb-3">
                        <label for="productId" class="form-label">Product</label>
                        <select class="form-select" id="productId" name="productId" required>
                            <option value="">Select a food</option>
                            @foreach (var food in ViewBag.Foods)
                            {
                                <option value="@food.Id" data-portion="@food.PortionName">@food.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="quantity" class="form-label" id="quantityLabel">Quantity (<span id="portionLabel">grams</span>)</label>
                        <input type="number" step="0.25" class="form-control" id="quantity" name="quantity" required>
                    </div>
                    <button type="submit" class="btn btn-primary">Add to Diary</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Today's Food</h5>
                    <div class="d-flex align-items-center">
                        <div class="me-2">
                            <a href="@Url.Action("Index", new { date = date.AddDays(-1) })" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                            <a href="@Url.Action("Index", new { date = date.AddDays(1) })" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </div>
                        <form asp-action="CopyDailyIntake" method="post" class="d-flex align-items-center">
                            <input type="hidden" name="targetDate" value="@date.ToString("yyyy-MM-dd")" />
                            <label class="me-2 mb-0">Copy from:</label>
                            <input type="date" name="sourceDate" class="form-control form-control-sm me-2"
                                   value="@(date.AddDays(-1).ToString("yyyy-MM-dd"))"
                                   max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Copy</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Intakes.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Quantity</th>
                                    <th>Calories</th>
                                    <th>Carbs</th>
                                    <th>Fat</th>
                                    <th>Protein</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var intake in Model.Intakes)
                                {
                                    <tr>
                                        <td>@intake.Product.Name</td>
                                        <td>
                                            <form asp-action="EditIntakeQuantity" method="post" class="d-flex align-items-center">
                                                <input type="hidden" name="id" value="@intake.Id" />
                                                <input type="number" name="quantity" min="0.01" step="0.01"
                                                       value="@intake.Quantity.ToString("F2")"
                                                       class="form-control form-control-sm me-1" style="width: 70px;" />
                                                       <label>@intake.Product.PortionName</label>
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            </form>
                                        </td>

                                        <td>@(((intake.Quantity / intake.Product.PortionSize) * intake.Product.CaloriesPerPortion).ToString("F1"))</td>
                                        <td>@(((intake.Quantity / intake.Product.PortionSize) * intake.Product.CarbsPerPortion).ToString("F1"))</td>
                                        <td>@(((intake.Quantity / intake.Product.PortionSize) * intake.Product.FatPerPortion).ToString("F1"))</td>
                                        <td>@(((intake.Quantity / intake.Product.PortionSize) * intake.Product.ProteinPerPortion).ToString("F1"))</td>
                                        <td>
                                            <form asp-action="RemoveIntake" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@intake.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No food logged for this day.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // keep existing intakeDate behavior
        document.getElementById('intakeDate').addEventListener('change', function () {
            // Оновити URL при зміні дати
            const selectedDate = this.value;
            window.location.href = `@Url.Action("Index")?date=${selectedDate}`;
        });

        // update the portion label whenever a new food is selected
        (function () {
            const productSelect = document.getElementById('productId');
            const portionLabel = document.getElementById('portionLabel');

            function updatePortionLabel() {
                const opt = productSelect.options[productSelect.selectedIndex];
                const portion = opt?.dataset?.portion || 'grams';
                portionLabel.textContent = portion;
            }

            // update on change
            productSelect.addEventListener('change', updatePortionLabel);

            // initialize on load (if a product is preselected)
            document.addEventListener('DOMContentLoaded', updatePortionLabel);
            // also run immediately in case DOMContentLoaded already fired
            updatePortionLabel();
        })();
    </script>
}